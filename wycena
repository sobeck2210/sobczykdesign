<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Montserrat+Alternates:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Oswald:wght@200..700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <link href="style.css" rel="stylesheet" />
    <link
      rel="icon"
      href="img/favicon_io/android-chrome-512x512.png"
      type="image/png"
    />
    <title>Zamów wycenę strony internetowej</title>
    <meta
      name="description"
      content="Chcesz wycenić stronę internetową? Wypełnij krótki formularz i otrzymaj darmową wycenę projektu dopasowaną do Twoich potrzeb."
    />
  </head>
  <body>
    <nav class="navbar-non-transparent">
      <div class="logo-container">
        <a href="https://sobczykdesign.pl/"
          ><img
            src="img/logo_czarne.webp"
            alt="Logo Sobczyk Design - twój pomysł na stronę - moja realizacja"
            class="logo"
        /></a>
      </div>
      <div class="nav-links-non-transparent">
        <a href="/o-mnie" class="nav-link-color">O mnie</a>
        <a href="/oferta" class="nav-link-color">Oferta</a>
        <a href="/blog" class="nav-link-color">Blog</a>
        <a href="/portfolio" class="nav-link-color">Realizacje</a>
        <a href="/kontakt" class="nav-link-color">Kontakt</a>
        <a href="/wycena" class="nav-btn">Wycena</a>
      </div>
    </nav>
    <section class="quote-form-section">
      <div class="quote-container">
        <h2 class="section-header margin-bottom-small">
          Napisz do mnie o wycenę
        </h2>
        <p class="margin-bottom-medium">
          Podziel się swoją wizją – razem stworzymy coś, co będzie działać i
          wyglądać świetnie. Zostaw mi kilka informacji, a wrócę do Ciebie z
          konkretną propozycją.
        </p>

        <form
          action="https://formspree.io/f/mgvknevy"
          method="POST"
          class="quote-form"
        >
          <!-- Dane kontaktowe -->
          <div class="form-group">
            <label for="name">Imię*</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Wpisz swoje imię"
              required
            />
          </div>
          <div class="form-group">
            <label for="email">E-mail*</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="Wpisz swój adres email"
              required
            />
          </div>
          <div class="form-group">
            <label for="phone">Telefon</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="Podaj nr telefonu"
            />
          </div>
          <div class="form-group">
            <label for="company">Nazwa firmy</label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Nazwa Twojej Firmy"
            />
          </div>

          <!-- Wybór usługi -->
          <div class="form-group">
            <label for="service">Co chcesz zamówić?*</label>
            <select id="service" name="service" required>
              <option value="" disabled selected>Wybierz</option>
              <option value="strona">Strona internetowa</option>
              <option value="logo">Projekt logo</option>
              <option value="inne">Inne</option>
            </select>
          </div>

          <div class="form-group">
            <label for="budget">Budżet*</label>
            <select id="budget" name="budget" required>
              <option value="" disabled selected>Wybierz</option>
              <option value="500-1000">500–1000 zł</option>
              <option value="1000-2000">1000–2000 zł</option>
              <option value="2000-5000">2000–5000 zł</option>
              <option value="5000+">5000 zł+</option>
            </select>
          </div>

          <div class="form-group">
            <label for="deadline">Termin realizacji</label>
            <input
              type="text"
              id="deadline"
              name="deadline"
              placeholder="Np. ASAP, 2 tygodnie, konkretna data"
            />
          </div>

          <!-- Opis projektu -->
          <div class="form-group">
            <label for="message">Opisz swój projekt*</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>

          <div class="form-group">
            <label for="references">Linki / inspiracje (opcjonalnie)</label>
            <textarea
              id="references"
              name="references"
              rows="3"
              placeholder="Podaj linki do stron, które Ci się podobają itp."
            ></textarea>
          </div>

          <!-- Przycisk -->
          <button type="submit" class="nav-btn">Wyślij zapytanie</button>
        </form>
      </div>
    </section>
    <section class="footer">
      <div class="footer-content">
        <div class="footer-column">
          <img
            src="img/logo_białe.webp"
            class="logo-footer"
            alt="Logo białe Sobczyk Design - zaprojektuj ze mną swoją stronę internetową"
          />
          <p>
            Strony internetowe, które wyróżniają się na tle konkurencji. Jesteś
            zainteresowany współpracą? Zadzwoń lub Napisz teraz!
          </p>
        </div>
        <div class="footer-column">
          <p class="footer-header margin-bottom-small">Nawigacja</p>
          <div class="footer-links">
            <a href="/o-mnie" class="footer-link">O mnie</a>
            <a href="/oferta" class="footer-link">Oferta</a>
            <a href="/portfolio" class="footer-link">Realizacje</a>
            <a href="/kontakt" class="footer-link">Kontakt</a>
          </div>
        </div>
        <div class="footer-column">
          <p class="footer-header margin-bottom-small">Oferta</p>
          <div class="footer-links">
            <a href="/oferta" class="footer-link">Strona wizytówka</a>
            <a href="/oferta" class="footer-link">Strona firmowa</a>
            <a href="/oferta" class="footer-link">Projekt logo</a>
          </div>
        </div>
        <div class="footer-column">
          <p class="footer-header margin-bottom-small">Kontakt</p>
          <div class="footer-links">
            <a href="mailto:hello@sobczykdesign.pl" class="footer-link"
              ><ion-icon
                name="mail-unread-outline"
                class="footer-icon"
              ></ion-icon>
              hello@sobczykdesign.pl</a
            >
            <a href="tel:+48579638033" class="footer-link"
              ><ion-icon name="call-outline" class="footer-icon"></ion-icon>
              579638033</a
            >
            <div class="sm-bar">
              <a href="#" class="footer-link"
                ><ion-icon name="logo-facebook" class="footer-icon"></ion-icon
              ></a>
              <a href="#" class="footer-link"
                ><ion-icon name="logo-whatsapp" class="footer-icon"></ion-icon
              ></a>
              <a href="#" class="footer-link"
                ><ion-icon name="logo-instagram" class="footer-icon"></ion-icon
              ></a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>
