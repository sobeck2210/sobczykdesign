    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const animated2Elements = document.querySelectorAll(".animated2");
        console.log("Znaleziono elementy:", animated2Elements.length);

        const observer = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                console.log("W zasięgu widoku:", entry.target);
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.2,
          }
        );

        animated2Elements.forEach((el) => observer.observe(el));
      });
    </script>
